{
  "entities": {
    "budgetEntry": {
      "title": "Budget Entry",
      "description": "A single marketing expenditure entry.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "productName": { "type": "string" },
        "amount": { "type": "number" },
        "teamMember": { "type": "string" },
        "type": { "type": "string", "enum": ["Total", "Advanced"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "date", "productName", "amount", "teamMember", "type", "createdAt"]
    }
  },
  "firestore": {
    "/budgetEntries/{entryId}": {
      "schema": "budgetEntry",
      "description": "Collection of all budget entries."
    }
  }
}
